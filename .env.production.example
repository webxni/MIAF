# --- General ---
ENVIRONMENT=production
LOG_LEVEL=info
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-secret

# --- Postgres (internal network only) ---
POSTGRES_USER=miaf
# Use a long random value (32+ chars).
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
POSTGRES_DB=miaf
# After first boot, point the running app/worker/scheduler at the non-super app role:
# DATABASE_URL=postgresql+asyncpg://miaf_app:<replace-with-MIAF_APP_ROLE_PASSWORD>@postgres:5432/miaf
# Used to set the non-super app-role password after init; override the placeholder immediately.
MIAF_APP_ROLE_PASSWORD=replace-with-a-long-random-app-role-password

# --- Redis (internal network only) ---
# Use a long random value (32+ chars).
REDIS_PASSWORD=replace-with-a-long-random-redis-password

# --- MinIO (internal only; console is not exposed in prod) ---
# Use long random values (32+ chars each).
MINIO_ROOT_USER=replace-with-a-long-random-minio-user
# Must be at least 8 characters.
MINIO_ROOT_PASSWORD=replace-with-a-long-random-minio-password
MINIO_BUCKET=miaf

# --- Web / API ---
NEXT_PUBLIC_API_URL=/api
# Set this to the literal production origin, e.g. https://miaf.example.com
CORS_ALLOW_ORIGINS=https://miaf.example.com

# --- Reverse proxy (Caddy) ---
# Real domain pointed at this VM, e.g. miaf.example.com
CADDY_DOMAIN=miaf.example.com
# Real ops email for ACME / Let's Encrypt expiry notices
CADDY_ADMIN_EMAIL=ops@example.com
HTTP_PORT=80
HTTPS_PORT=443

# --- Backup ---
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=7

# --- Scheduler ---
HEARTBEAT_INTERVAL_SECONDS=300
# Required so scheduler can call /internal/heartbeat/run-defaults
AUTOMATION_TOKEN=replace-with-a-long-random-automation-token

# --- Optional OpenAI document reading ---
OPENAI_DOCUMENT_AI_REQUIRES_CONSENT=true
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_PDF_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_DOCUMENT_MAX_FILE_MB=10
OPENAI_DOCUMENT_TIMEOUT_SECONDS=45
