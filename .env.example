# --- General ---
ENVIRONMENT=development
LOG_LEVEL=info
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# --- Postgres (internal network only) ---
POSTGRES_USER=miaf
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=miaf

# --- Redis (internal network only) ---
REDIS_PASSWORD=change-me-redis-password

# --- MinIO (internal; console exposed on 127.0.0.1:9001 in dev only) ---
MINIO_ROOT_USER=miaf
# Must be at least 8 characters
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET=miaf

# --- Web ---
NEXT_PUBLIC_API_URL=/api

# --- Reverse proxy (Caddy) ---
HTTP_PORT=80
HTTPS_PORT=443
# Production only — domain Caddy serves. In dev we listen on :80.
CADDY_DOMAIN=localhost

# --- Backup ---
BACKUP_RETENTION_DAYS=7

# --- Scheduler ---
HEARTBEAT_INTERVAL_SECONDS=300

# --- Internal automation (required — change before first deploy) ---
# Used to authenticate the scheduler's internal heartbeat calls.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTOMATION_TOKEN=change-me-automation-token

# --- AI providers (optional — at least one required for LLM planning) ---
# Leave blank to use the deterministic heuristic fallback.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Production: restrict trusted proxy IPs for X-Forwarded-For ---
# Default allows all (fine behind a single Docker network; tighten for multi-hop).
# Example: 172.18.0.0/16
UVICORN_FORWARDED_IPS=*
