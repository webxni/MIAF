# --- General ---
ENVIRONMENT=development
LOG_LEVEL=info
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
# Optional explicit app DB URL override. By default compose derives this from POSTGRES_*.
# DATABASE_URL=postgresql+asyncpg://miaf:change-me-postgres-password@postgres:5432/miaf

# --- Postgres (internal network only) ---
POSTGRES_USER=miaf
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=miaf

# --- Redis (internal network only) ---
REDIS_PASSWORD=change-me-redis-password
# Optional explicit app Redis URL override.
# REDIS_URL=redis://:change-me-redis-password@redis:6379/0

# --- MinIO (internal; console exposed on 127.0.0.1:9001 in dev only) ---
MINIO_ROOT_USER=miaf
# Must be at least 8 characters
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET=miaf
# App containers derive these from the root values above unless overridden.
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=miaf
MINIO_SECRET_KEY=change-me-minio-password
MINIO_SECURE=false

# --- Web ---
NEXT_PUBLIC_API_URL=/api

# --- API / auth / security ---
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SESSION_COOKIE_NAME=miaf_session
IP_RATE_LIMIT_WINDOW_SECONDS=60
IP_RATE_LIMIT_REQUESTS=120

# --- Reverse proxy (Caddy) ---
HTTP_PORT=80
HTTPS_PORT=443
# Production only — domain Caddy serves. In dev we listen on :80.
CADDY_DOMAIN=localhost

# --- Backup ---
BACKUP_RETENTION_DAYS=7

# --- Scheduler ---
HEARTBEAT_INTERVAL_SECONDS=300

# --- Internal automation (required — change before first deploy) ---
# Used to authenticate the scheduler's internal heartbeat calls.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTOMATION_TOKEN=change-me-automation-token

# --- AI providers (optional — at least one required for LLM planning) ---
# Leave blank to use the deterministic heuristic fallback.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_DOCUMENT_AI_REQUIRES_CONSENT=true
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_PDF_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_DOCUMENT_MAX_FILE_MB=10
OPENAI_DOCUMENT_TIMEOUT_SECONDS=45

# --- Integrations ---
TELEGRAM_WEBHOOK_SECRET=

# --- Tailscale (optional) ---
TAILSCALE_BINARY_PATH=/usr/bin/tailscale
TAILSCALE_COMMAND_TIMEOUT=10
TAILSCALE_ALLOWED_PORTS=80

# --- Production: restrict trusted proxy IPs for X-Forwarded-For ---
# Default allows all (fine behind a single Docker network; tighten for multi-hop).
# Example: 172.18.0.0/16
UVICORN_FORWARDED_IPS=*
